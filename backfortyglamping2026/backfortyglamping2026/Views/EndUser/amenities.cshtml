@{
    ViewBag.Title = "amenities";
    Layout = "~/Views/Shared/_LayoutEUMaster.cshtml";
}

@section MetaSection{
<title>Back Forty Glamping Amenities | Comfort in Nature</title>
    <meta name="description" content="Explore luxury glamping amenities from private hot tubs and EV chargers to a tranquil pond, walking trails, firepit, library, and snowshoe for a comfortable stay." />
}
    <span id="MenuId" style="display: none;">amenities</span>

<main>
    
    <section title="Couple in Hammock at Back Forty Glamping" class="hero-banner" style="background: url('../../assets/images/couple-in-hammock-at-back-forty-glamping.webp');"></section>
    <div class="banner-bottomdesign">
        <img src="../../assets/images/banner-bottomdesign.webp" class="img-fluid w-100 h-100" alt="banner-bottomdesign" loading="lazy">
    </div>

    <section class="mainsec amenities-mainsec">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="main-heading">
                        <h1>Luxury Amenities for Your Glamping Stay in Meaford</h1>
                        <p>
                            At Back Forty Glamping, thoughtful amenities help you relax, recharge, and enjoy the outdoors at your own pace. From unwinding in the sauna to wandering peaceful walking trails, every detail is designed to make your stay comfortable and memorable. Spend quiet moments in the forest library, enjoy our pond views, take advantage of EV charging, and rest easy with free on-site parking throughout your stay.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="addons-sec amenitiesslider amenitiespage">
        <div class="container-fluid">
            <div class="row amenities-desk-row">
                <div class="col-md-6">
                    <div class="amenities-box">
                        <div class="addons-img">
                            <img src="../../assets/images/exterior-sauna-winter.webp" class="img-fluid" alt="Exterior Sauna-winter" loading="lazy">
                        </div>
                        <div class="addons-desc">
                            <h3>Sauna</h3>
                            <p>
                                Follow the wooden boardwalk to our electric sauna, where panoramic forest views invite you to slow down. Cool off with the cold shower and soak in the peaceful sights and sounds of nature.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mt-md-0 mt-5">
                    <div class="amenities-box">
                        <div class="addons-img">
                            <img src="../../assets/images/forest-library.webp" class="img-fluid" alt="Forest Library" loading="lazy">
                        </div>
                        <div class="addons-desc">
                            <h3>Forest Library</h3>
                            <p>
                                Settle in by the wood-burning fireplace and enjoy peaceful forest views. Browse our thoughtfully curated collection of books and games — a cozy space to slow down, unplug, and unwind.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mt-md-0 mt-5">
                    <div class="amenities-box">
                        <div class="addons-img">
                            <img src="../../assets/images/back-forty-pond.webp" class="img-fluid" alt="Back Forty Pond" loading="lazy">
                        </div>
                        <div class="addons-desc">
                            <h3>Pond</h3>
                            <p>
                                Relax in the hammock by the pond and take in the quiet surroundings. Keep an eye out for turtles sunning themselves and frogs nearby — a peaceful spot to pause and enjoy nature.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mt-md-0 mt-5">
                    <div class="amenities-box">
                        <div class="addons-img">
                            <img src="../../assets/images/walking-trails-at-back-forty-glamping.webp" class="img-fluid" alt="Walking Trails at Back Forty Glamping" loading="lazy">
                        </div>
                        <div class="addons-desc">
                            <h3>Walking Trails</h3>
                            <p>
                                Explore 2 km of winding trails across our 25-acre property. Immerse yourself in the sights and sounds of the forest, discovering quiet corners and hidden spots perfect for a reflective stroll.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mt-md-0 mt-5">
                    <div class="amenities-box">
                        <div class="addons-img">
                            <img src="../../assets/images/ev-chargers-in-parking-lot.webp" class="img-fluid" alt="EV Chargers In Parking Lot" loading="lazy">
                        </div>
                        <div class="addons-desc">
                            <h3>EV Charging</h3>
                            <p>
                                Charge your electric vehicle worry-free with our two convenient, complimentary chargers. Stay powered up while you relax and enjoy the peaceful surroundings of Back Forty Glamping.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mt-md-0 mt-5">
                    <div class="amenities-box">
                        <div class="addons-img">
                            <img src="../../assets/images/free-parking.webp" class="img-fluid" alt="Free Parking While you Glamp" loading="lazy">
                        </div>
                        <div class="addons-desc">
                            <h3>Free Parking</h3>
                            <p>
                                Enjoy safe, secure, and hassle-free parking on-site, so you can start your glamping getaway relaxed and worry-free from the moment you arrive.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

