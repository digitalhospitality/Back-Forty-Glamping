    ViewBag.Title = "dining";
    Layout = "~/Views/Shared/_LayoutEUMaster.cshtml";
}

@section MetaSection{
<title>Glamping Dining Options | Fresh, Local & Chef-Crafted Meals</title>
    <meta name="description" content="Savor the flavors of South Georgian Bay while glamping at Back Forty. From rustic cafes and local bakeries to gourmet restaurants and wineries." />
}
    <span id="MenuId" style="display: none;">dining</span>

